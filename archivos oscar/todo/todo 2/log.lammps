# Definir el estilo de pares hybrid
pair_style hybrid lj/cut/coul/long 10.0 lj/cut 10.0

# Coeficientes de interacciones para el carbono del grafeno
pair_coeff 1 1 lj/cut 0.1480000000 3.6170000000 10.0  # C (grafeno)

# Coeficientes de interacciones para la arcilla
pair_coeff 2 2 lj/cut/coul/long 0.0000013298 4.2712400000 10.0  # ao (arcilla)
pair_coeff 3 3 lj/cut/coul/long 0.0000009030 5.2643200000 10.0  # mgo (arcilla)
pair_coeff 4 4 lj/cut/coul/long 0.0000018405 3.3020300000 10.0  # st (arcilla)
pair_coeff 5 5 lj/cut/coul/long 0.0000018405 3.3020300000 10.0  # at (arcilla)
pair_coeff 6 6 lj/cut/coul/long 0.1554000000 3.1655400000 10.0  # ob (arcilla)
pair_coeff 7 7 lj/cut/coul/long 0.1554000000 3.1655400000 10.0  # ohy (arcilla)
pair_coeff 9 9 lj/cut/coul/long 0.1554000000 3.1655400000 10.0  # obos (arcilla)
pair_coeff 10 10 lj/cut/coul/long 0.1554000000 3.1655400000 10.0  # ohs (arcilla)
pair_coeff 8 8 lj/cut/coul/long 0.1554000000 3.1655400000 10.0  # obts (arcilla)
pair_coeff 11 11 lj/cut/coul/long 0.0000000000 0.0000000000 10.0  # hoy (arcilla)
pair_coeff 12 12 lj/cut/coul/long 0.1553000000 2.2344000000 10.0  # na (arcilla)
pair_coeff 13 13 lj/cut/coul/long 0.1553000000 3.1660000000 10.0  # ow (arcilla_agua)
pair_coeff 14 14 lj/cut/coul/long 0.0000000000 0.0000000000 10.0  # hw (arcilla_agua)

# Coeficientes de interacciones cruzadas entre carbono del grafeno y arcilla
pair_coeff 1 2 lj/cut 0.000443633 3.94412 10.0  # C - ao (interacción cruzada)
pair_coeff 1 3 lj/cut 0.000365574 4.44066 10.0  # C - mgo (interacción cruzada)
pair_coeff 1 4 lj/cut 0.000521914 3.459515 10.0  # C - st (interacción cruzada)
pair_coeff 1 5 lj/cut 0.000521914 3.459515 10.0  # C - at (interacción cruzada)
pair_coeff 1 6 lj/cut 0.151654871 3.39127 10.0  # C - ob (interacción cruzada)
pair_coeff 1 7 lj/cut 0.151654871 3.39127 10.0  # C - ohy (interacción cruzada)
pair_coeff 1 9 lj/cut 0.151654871 3.39127 10.0  # C - obos (interacción cruzada)
pair_coeff 1 10 lj/cut 0.151654871 3.39127 10.0  # C - ohs (interacción cruzada)
pair_coeff 1 8 lj/cut 0.151654871 3.39127 10.0 # C - obts (interacción cruzada)
pair_coeff 1 11 lj/cut 0.000000000 1.8085 10.0 # C - hoy (interacción cruzada)
pair_coeff 1 12 lj/cut 0.151606068 2.9257 10.0 # C - na (interacción cruzada)
pair_coeff 1 13 lj/cut 0.151606068 3.3915 10.0 # C - ow (interacción cruzada)
pair_coeff 1 14 lj/cut 0.000000000 1.8085 10.0 # C - hw (interacción cruzada)

# Definir kspace_style para manejar las interacciones electrostáticas de largo alcance
kspace_style pppm 1.0e-4

# Relajación con minimize
thermo_style custom step temp epair ebond eangle edihed eimp pe ke etotal press
thermo 100
minimize 0.0 1.0e-8 10000 100000
